{
  "agent_servers": {
    "opencode": {
      "type": "registry",
    },
    "codex-acp": {
      "type": "registry",
    },
  },
  "project_panel": {
    "dock": "left",
  },
  "outline_panel": {
    "dock": "left",
  },
  "collaboration_panel": {
    "dock": "left",
  },
  "git_panel": {
    "dock": "left",
    "tree_view": true,
  },
  "base_keymap": "VSCode",
  "vim_mode": true,
  "relative_line_numbers": "enabled",
  // "double_click_in_multibuffer": "open",
  "confirm_quit": false,
  "show_edit_predictions": true,
  "agent": {
    "dock": "right",
    "default_model": {
      "provider": "copilot_chat",
      "model": "claude-sonnet-4.5",
    },
    "use_modifier_to_send": true,
    "play_sound_when_agent_done": "always",
    "single_file_review": true,
    "default_profile": "ask",
  },
  "edit_predictions": {
    "provider": "copilot",
    "mode": "subtle",
    "copilot": {
      "proxy": null,
      "proxy_no_verify": null,
      "enterprise_uri": null,
    },
    "enabled_in_text_threads": false,
  },
  "minimap": {
    "show": "never",
  },
  "inlay_hints": {
    "enabled": false,
    "show_value_hints": true,
    "show_type_hints": true,
    "show_parameter_hints": true,
    "show_other_hints": true,
    "show_background": false,
    "edit_debounce_ms": 700,
    "scroll_debounce_ms": 50,
    "toggle_on_modifiers_press": {
      "control": true,
      "alt": false,
      "shift": true,
      "platform": true,
      "function": false,
    },
  },
  "icon_theme": "Material Icon Theme",
  "telemetry": {
    "diagnostics": false,
    "metrics": false,
  },
  "ui_font_size": 16,
  "buffer_font_size": 15,
  // "buffer_font_family": "CommitMono",
  "buffer_font_family": "Berkeley Mono",
  // "buffer_font_family": "Comic Code Ligatures",
  // "buffer_font_family": "Fira Code",
  // "buffer_font_family": "JetBrains Mono",
  "buffer_line_height": "standard",
  "theme": {
    "mode": "system",
    "light": "Catppuccin Latte - No Italics",
    "dark": "Catppuccin Frappé - No Italics",
  },
  "git": {
    "inline_blame": {
      "enabled": false,
    },
  },
  "languages": {
    "TSX": {
      "tab_size": 2,
    },
    "JavaScript": {
      "tab_size": 2,
    },
    "TypeScript": {
      "tab_size": 2,
    },
    "Templ": {
      "language_servers": [
        "templ",
        "vscode-html-language-server",
        "tailwindcss-language-server",
        "emmet-language-server",
      ],
    },
  },
  "profiles": {
    // "laptop": {
    //   "ui_font_size": 15
    // },
    "presentation": {
      // "vim_mode": false,
      "settings": {
        "buffer_font_size": 18,
        "ui_font_size": 18,
        "theme": "One Light",
        "relative_line_numbers": "disabled",
      },
    },
    "HiDPI": {
      "settings": {
        "buffer_font_size": 17,
        "ui_font_size": 17,
      },
    },
  },
  "file_finder": {
    "modal_max_width": "medium",
  },
  "tabs": {
    "git_status": true,
    "file_icons": true,
    "show_diagnostics": "all",
  },
  "current_line_highlight": "gutter",
  "status_bar": {
    "line_endings_button": true,
  },
  "lsp": {
    "tailwindcss-language-server": {
      "settings": {
        "experimental": {
          "classRegex": [
            "\\w*[Cc]lassName\\s*=\\s*[\"']([^\"']*)[\"']",
            "\\w*[Cc]lassName\\s*=\\s*{`([^`]*)`}",
          ],
        },
      },
    },
  },
  "sticky_scroll": {
    "enabled": true,
  },
}
